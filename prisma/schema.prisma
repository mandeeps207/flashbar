// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
  engineType = "client"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model BannerSetting {
  id              String   @id @default(cuid())
  shop            String   @unique
  text            String   @default("Flash Sale!")
  targetDate      DateTime
  isEvergreen     Boolean  @default(false)
  minutesDuration Int      @default(15)
  backgroundColor String   @default("#000000")
  textColor       String   @default("#ffffff")
  buttonText      String   @default("Shop now")
  buttonUrl       String   @default("")
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shop])
}

model AnnouncementCta {
  id              String     @id @default(cuid())
  shop            String
  name            String     @default("Weekend sale timer")
  text            String     @default("Flash Sale!")
  headingHtml     String     @default("Flash Sale!")
  targetDate      DateTime
  isEvergreen     Boolean    @default(false)
  minutesDuration Int        @default(15)
  displayType     String     @default("inline")
  placement       String     @default("theme_block")
  isSticky        Boolean    @default(false)
  stickyPosition  String     @default("top")
  backgroundColor String     @default("#000000")
  textColor       String     @default("#ffffff")
  timerBackground String     @default("#111111")
  timerTextColor  String     @default("#ffffff")
  digitColor      String     @default("#ffffff")
  labelColor      String     @default("#d1d5db")
  buttonBackground String    @default("#ffffff")
  buttonTextColor String     @default("#000000")
  buttonText      String     @default("Shop now")
  buttonUrl       String     @default("")
  borderRadius    Int        @default(6)
  isEnabled       Boolean    @default(true)
  priority        Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  events          CtaEvent[]

  @@index([shop])
  @@index([shop, isEnabled, priority])
}

model CtaEvent {
  id        String          @id @default(cuid())
  shop      String
  ctaId     String?
  type      String
  device    String          @default("unknown")
  source    String          @default("direct")
  path      String          @default("")
  createdAt DateTime        @default(now())
  cta       AnnouncementCta? @relation(fields: [ctaId], references: [id], onDelete: SetNull)

  @@index([shop, type, createdAt])
  @@index([ctaId, type, createdAt])
}
