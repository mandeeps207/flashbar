{% liquid
  assign block_id = 'flashbar-' | append: block.id
  assign proxy_url = block.settings.proxy_url | default: '/apps/flashbar/settings'
  assign track_url = block.settings.track_url | default: '/apps/flashbar/track'
%}

<div
  id="{{ block_id }}"
  class="flashbar"
  data-proxy-url="{{ proxy_url }}"
  data-track-url="{{ track_url }}"
  data-shop="{{ shop.permanent_domain }}"
  data-text="{{ block.settings.text | escape }}"
  data-heading-html="{{ block.settings.text | escape }}"
  data-target-date="{{ block.settings.target_date | escape }}"
  data-evergreen="{{ block.settings.is_evergreen }}"
  data-minutes="{{ block.settings.minutes_duration }}"
  data-display-type="inline"
  data-placement="theme_block"
  data-sticky="false"
  data-sticky-position="top"
  data-background="{{ block.settings.background_color }}"
  data-color="{{ block.settings.text_color }}"
  data-timer-background="#111111"
  data-timer-text-color="#ffffff"
  data-digit-color="#ffffff"
  data-label-color="#d1d5db"
  data-button-background="#ffffff"
  data-button-text-color="#000000"
  data-border-radius="6"
  data-button-text="{{ block.settings.button_text | escape }}"
  data-button-url="{{ block.settings.button_url }}"
  data-enabled="{{ block.settings.is_enabled }}"
  hidden
>
  <div class="flashbar__inner">
    <span class="flashbar__text"></span>
    <span class="flashbar__timer" aria-live="polite">
      <span class="flashbar__timer-cell"><span data-unit="days">00</span><small>Days</small></span>
      <span class="flashbar__timer-cell"><span data-unit="hours">00</span><small>Hours</small></span>
      <span class="flashbar__timer-cell"><span data-unit="minutes">00</span><small>Mins</small></span>
      <span class="flashbar__timer-cell"><span data-unit="seconds">00</span><small>Secs</small></span>
    </span>
    <a class="flashbar__button"></a>
  </div>
</div>

<style>
  #{{ block_id }} {
    background: #000;
    color: #fff;
    font: inherit;
    width: 100%;
    z-index: 2147483000;
  }

  #{{ block_id }}[hidden] {
    display: none;
  }

  #{{ block_id }} .flashbar__inner {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    min-height: 48px;
    padding: 10px 16px;
    text-align: center;
  }

  #{{ block_id }} .flashbar__text {
    font-weight: 700;
  }

  #{{ block_id }} .flashbar__timer {
    border-radius: 6px;
    display: inline-flex;
    font-variant-numeric: tabular-nums;
    gap: 6px;
    padding: 6px;
  }

  #{{ block_id }} .flashbar__timer-cell {
    align-items: center;
    border-radius: 4px;
    display: inline-flex;
    flex-direction: column;
    font-weight: 700;
    min-width: 42px;
    padding: 4px 6px;
  }

  #{{ block_id }} .flashbar__timer-cell small {
    font-size: 10px;
    font-weight: 500;
    line-height: 1.1;
  }

  #{{ block_id }} .flashbar__button {
    background: currentColor;
    border-radius: 6px;
    padding: 7px 12px;
    text-decoration: none;
  }
</style>

<script>
  (() => {
    const root = document.getElementById({{ block_id | json }});
    if (!root || root.dataset.booted) return;
    root.dataset.booted = "true";

    const fallback = {
      text: root.dataset.text || "Flash Sale!",
      headingHtml: root.dataset.headingHtml || root.dataset.text || "Flash Sale!",
      targetDate: root.dataset.targetDate || new Date(Date.now() + 6048e5).toISOString(),
      isEvergreen: root.dataset.evergreen === "true",
      minutesDuration: Number(root.dataset.minutes || 15),
      displayType: root.dataset.displayType || "inline",
      placement: root.dataset.placement || "theme_block",
      isSticky: root.dataset.sticky === "true",
      stickyPosition: root.dataset.stickyPosition || "top",
      backgroundColor: root.dataset.background || "#000000",
      textColor: root.dataset.color || "#ffffff",
      timerBackground: root.dataset.timerBackground || "#111111",
      timerTextColor: root.dataset.timerTextColor || "#ffffff",
      digitColor: root.dataset.digitColor || "#ffffff",
      labelColor: root.dataset.labelColor || "#d1d5db",
      buttonBackground: root.dataset.buttonBackground || "#ffffff",
      buttonTextColor: root.dataset.buttonTextColor || "#000000",
      buttonText: root.dataset.buttonText || "Shop now",
      buttonUrl: root.dataset.buttonUrl || "",
      borderRadius: Number(root.dataset.borderRadius || 6),
      isEnabled: root.dataset.enabled !== "false"
    };

    const timerNodes = {
      days: root.querySelector('[data-unit="days"]'),
      hours: root.querySelector('[data-unit="hours"]'),
      minutes: root.querySelector('[data-unit="minutes"]'),
      seconds: root.querySelector('[data-unit="seconds"]')
    };

    const cookieName = "flashbar_end_" + btoa(location.hostname).replaceAll("=", "");
    const pad = (value) => String(Math.max(0, value)).padStart(2, "0");
    const readCookie = (name) => document.cookie.split("; ").find((row) => row.startsWith(name + "="))?.split("=")[1];
    const writeCookie = (name, value, maxAge) => {
      document.cookie = name + "=" + value + "; path=/; max-age=" + maxAge + "; samesite=lax";
    };

    const source = () => {
      const params = new URLSearchParams(location.search);
      return params.get("utm_source") || document.referrer && new URL(document.referrer).hostname || "direct";
    };

    const safeHtml = (html) => {
      const template = document.createElement("template");
      template.innerHTML = String(html || "");
      template.content.querySelectorAll("*").forEach((node) => {
        if (!["STRONG", "B", "EM", "I", "SPAN", "BR"].includes(node.tagName)) {
          node.replaceWith(document.createTextNode(node.textContent || ""));
          return;
        }
        [...node.attributes].forEach((attribute) => node.removeAttribute(attribute.name));
      });
      return template.innerHTML;
    };

    const track = (settings, type) => {
      const url = new URL(root.dataset.trackUrl, location.origin);
      url.searchParams.set("shop", root.dataset.shop);
      fetch(url, {
        body: JSON.stringify({
          ctaId: settings.id || null,
          path: location.pathname,
          source: source(),
          type
        }),
        credentials: "same-origin",
        headers: { "content-type": "application/json" },
        method: "POST",
        keepalive: true
      }).catch(() => {});
    };

    const apply = (settings) => {
      if (!settings.isEnabled) {
        root.hidden = true;
        return;
      }

      root.style.background = settings.backgroundColor;
      root.style.color = settings.textColor;
      root.style.borderRadius = Math.max(0, Number(settings.borderRadius || 0)) + "px";
      root.style.position = settings.isSticky ? "fixed" : "";
      root.style.left = settings.isSticky ? "0" : "";
      root.style.right = settings.isSticky ? "0" : "";
      root.style.top = settings.isSticky && settings.stickyPosition === "top" ? "0" : "";
      root.style.bottom = settings.isSticky && settings.stickyPosition === "bottom" ? "0" : "";

      const inner = root.querySelector(".flashbar__inner");
      inner.style.flexDirection = settings.displayType === "block" ? "column" : "row";
      root.querySelector(".flashbar__text").innerHTML = safeHtml(settings.headingHtml || settings.text);

      const timer = root.querySelector(".flashbar__timer");
      timer.style.background = settings.timerBackground;
      timer.style.color = settings.timerTextColor;
      timer.querySelectorAll("[data-unit]").forEach((node) => {
        node.style.color = settings.digitColor;
      });
      timer.querySelectorAll("small").forEach((node) => {
        node.style.color = settings.labelColor;
      });

      const button = root.querySelector(".flashbar__button");
      button.textContent = settings.buttonText || "";
      button.href = settings.buttonUrl || "#";
      button.hidden = !settings.buttonText;
      button.style.background = settings.buttonBackground;
      button.style.color = settings.buttonTextColor;
      button.onclick = () => track(settings, "click");

      let end = Date.parse(settings.targetDate);
      if (settings.isEvergreen) {
        const saved = Number(readCookie(cookieName));
        const duration = Math.max(1, Number(settings.minutesDuration || 15)) * 60000;
        end = saved && saved > Date.now() ? saved : Date.now() + duration;
        writeCookie(cookieName, String(end), Math.ceil(duration / 1000));
      }

      const tick = () => {
        const total = Math.max(0, Math.floor((end - Date.now()) / 1000));
        timerNodes.days.textContent = pad(Math.floor(total / 86400));
        timerNodes.hours.textContent = pad(Math.floor((total % 86400) / 3600));
        timerNodes.minutes.textContent = pad(Math.floor((total % 3600) / 60));
        timerNodes.seconds.textContent = pad(total % 60);
      };

      tick();
      root.hidden = false;
      track(settings, "impression");
      setInterval(tick, 1000);
    };

    const url = new URL(root.dataset.proxyUrl, location.origin);
    url.searchParams.set("shop", root.dataset.shop);

    fetch(url, { credentials: "same-origin" })
      .then((response) => response.ok ? response.json() : fallback)
      .then((settings) => {
        const ctas = Array.isArray(settings.ctas) ? settings.ctas : [];
        const chosen = ctas.length ? ctas[Math.floor(Math.random() * ctas.length)] : settings;
        apply({ ...fallback, ...chosen });
      })
      .catch(() => apply(fallback));
  })();
</script>

{% schema %}
{
  "name": "FlashBar timer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "proxy_url",
      "label": "App proxy URL",
      "default": "/apps/flashbar/settings"
    },
    {
      "type": "text",
      "id": "track_url",
      "label": "Tracking URL",
      "default": "/apps/flashbar/track"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Flash Sale!"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "Target date ISO",
      "default": "2030-01-01T00:00:00.000Z"
    },
    {
      "type": "checkbox",
      "id": "is_evergreen",
      "label": "Use evergreen timer",
      "default": false
    },
    {
      "type": "range",
      "id": "minutes_duration",
      "label": "Evergreen minutes",
      "min": 5,
      "max": 240,
      "step": 5,
      "default": 15
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "is_enabled",
      "label": "Enabled",
      "default": true
    }
  ]
}
{% endschema %}
