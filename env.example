SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SCOPES="write_products"
SHOPIFY_APP_URL="https://flashbar-eta.vercel.app"

# Supabase transaction-pooler URL for application/runtime queries.
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=30&sslmode=require"

# Supabase direct connection URL for Prisma migrations.
DIRECT_URL="postgresql://postgres.<project-ref>:<database-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
